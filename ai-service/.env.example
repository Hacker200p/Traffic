# ---- AI Service Environment ----

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2
ENV=development
DEBUG=true

# Backend API (Node.js traffic control service)
# The AI service calls /api/v1/integration/* routes with API-key auth
BACKEND_API_URL=http://localhost:3000/api/v1
BACKEND_API_KEY=your-service-api-key-min-32-chars-long!!
BACKEND_TIMEOUT=30

# YOLO Model Paths (relative to ai-service root)
YOLO_VEHICLE_MODEL=models/yolov8n.pt
YOLO_HELMET_MODEL=models/yolov8n.pt
YOLO_PLATE_MODEL=models/yolov8n.pt

# Detection Thresholds
VEHICLE_CONFIDENCE=0.45
HELMET_CONFIDENCE=0.50
PLATE_CONFIDENCE=0.40
RED_LIGHT_CONFIDENCE=0.50

# Traffic Density
DENSITY_LOW_THRESHOLD=5
DENSITY_MEDIUM_THRESHOLD=15
DENSITY_HIGH_THRESHOLD=30

# EasyOCR
OCR_LANGUAGES=en
OCR_GPU=false

# Processing
MAX_IMAGE_SIZE=4096
JPEG_QUALITY=85
BATCH_SIZE=8
MAX_CONCURRENT_TASKS=10

# Logging
LOG_LEVEL=DEBUG
LOG_DIR=logs
LOG_ROTATION=50 MB
LOG_RETENTION=30 days
