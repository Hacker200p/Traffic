# Environment
NODE_ENV=development
PORT=3000

# PostgreSQL (with PostGIS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=traffic_control
DB_USER=postgres
DB_PASSWORD=postgres_secret_password
DB_POOL_MIN=2
DB_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_password
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=logs

# WebSocket
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000

# Service-to-Service Auth (shared key with AI microservice)
SERVICE_API_KEY=your-service-api-key-min-32-chars-long!!
SERVICE_SYSTEM_USER_ID=00000000-0000-0000-0000-000000000001
